# path: sudo nano /usr/lib/systemd/system/land-reg.service  /etc/systemd/system/land-reg.service
# restart: sudo systemctl restart land-reg
[Unit]
Description=LangReg Service API
After=network.target remote-fs.target nss-lookup.target nginx.target
[Service]
ExecStart=/usr/bin/java -Xms3g -Xmx4g -server  -jar /home/landreg/LangRegDeployments/jar/optimize-land-reg.jar
User=landreg
[Install]
WantedBy=multi-user.target